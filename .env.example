# ─── The Opportunity — Environment Variables ──────────────────────────────────
# Copy this file to .env and fill in your values.
# NEVER commit .env to git. It is already in .gitignore.
# ─────────────────────────────────────────────────────────────────────────────

# Deployer wallet private key (hex, with 0x prefix)
# Use a dedicated deployment wallet — never your personal wallet.
DEPLOYER_PRIVATE_KEY=0x_YOUR_DEPLOYER_PRIVATE_KEY_HERE

# RPC endpoints — get from Alchemy (https://alchemy.com) or QuickNode
BASE_SEPOLIA_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY
BASE_MAINNET_RPC_URL=https://base-mainnet.g.alchemy.com/v2/YOUR_ALCHEMY_API_KEY

# Basescan API key — for contract verification
# Get from: https://basescan.org/myapikey
BASESCAN_API_KEY=YOUR_BASESCAN_API_KEY

# Protocol treasury address — receives the 0.5% protocol fee
# Must be set before any deployment. Use a multisig for mainnet.
PROTOCOL_TREASURY_ADDRESS=0x_YOUR_TREASURY_MULTISIG_ADDRESS

# Gelato keeper address — the ONLY address permitted to call executePull()
# Get this from your Gelato task setup. Record here before deploying contracts.
GELATO_KEEPER_ADDRESS=0x_YOUR_GELATO_TASK_WALLET_ADDRESS

# Gas reporter (optional — set to "true" to see gas costs after tests)
REPORT_GAS=false

# CoinMarketCap API key (optional — used by gas reporter for USD estimates)
COINMARKETCAP_API_KEY=
